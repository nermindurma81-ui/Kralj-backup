# 🔐 OpenClaw Railway - Environment Variables Template
# Kopiraj ovo u .env i popuni svojim vrijednostima

# ============================================
# 🚀 OPENCLAW CORE (OBAVEZNO)
# ============================================
OPENCLAW_WORKSPACE=/app/workspace
OPENCLAW_PORT=9110
OPENCLAW_HOST=0.0.0.0
NODE_ENV=production

# ============================================
# 🌐 GATEWAY CONFIG (OBAVEZNO)
# ============================================
GATEWAY_PORT=9110
GATEWAY_BIND=0.0.0.0
GATEWAY_MODE=local
GATEWAY_AUTH_MODE=trusted-proxy

# ============================================
# 🔐 SECURITY (OBAVEZNO ZA PRODUKCIJU)
# ============================================
# Kreiraj na: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ============================================
# 🎨 VERCEL INTEGRATION (OPCIONO)
# ============================================
# Kreiraj na: https://vercel.com/account/tokens
VERCEL_TOKEN=vcp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_PROJECT_ID=nermindurma1981-9691s-projects

# ============================================
# 🧠 AI PROVIDERS (OPCIONO - Preporučeno)
# ============================================
# Groq AI (https://console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ============================================
# 🎬 MEDIA & STOCK (OPCIONO)
# ============================================
# Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxx

# HuggingFace (https://huggingface.co/settings/tokens)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Pollinations AI (besplatan, ne treba key)
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt

# ============================================
# 📱 SOCIAL MEDIA (OPCIONO)
# ============================================
# YouTube OAuth (https://console.cloud.google.com/)
YOUTUBE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxx
YOUTUBE_REDIRECT_URI=https://your-domain.com/api/platforms/youtube/callback

# TikTok (https://developers.tiktok.com/)
TIKTOK_CLIENT_KEY=xxxxxxxxxxxxx
TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
TIKTOK_REDIRECT_URI=https://your-domain.com/api/platforms/tiktok/callback

# ============================================
# 📧 EMAIL & NOTIFICATIONS (OPCIONO)
# ============================================
# Telegram Bot (via @BotFather)
TELEGRAM_BOT_TOKEN=xxxxx:xxxxxxxxxxxxxxxxxxxx

# SendGrid (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ============================================
# 🗄️ DATABASE (OPCIONO)
# ============================================
# Supabase (https://app.supabase.com/project/_/settings/api)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxx.xxxxx

# PostgreSQL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis (Railway provides this automatically)
REDIS_URL=redis://user:password@host:6379

# ============================================
# 📊 MONITORING & ANALYTICS (OPCIONO)
# ============================================
ENABLE_METRICS=true
METRICS_ENDPOINT=/api/metrics
ENABLE_LOGGING=true
LOG_LEVEL=info

# ============================================
# 🎯 SHORTAI SPECIFIC (OPCIONO)
# ============================================
VIDEO_OUTPUT_DIR=/app/workspace/videos
MAX_CONCURRENT=5
DEFAULT_DURATION=30
DEFAULT_PLATFORM=youtube
DEFAULT_FPS=24
DEFAULT_RESOLUTION=1080x1920
ENABLE_CACHE=true
MAX_RETRIES=3

# ============================================
# ⚙️ PERFORMANCE TUNING (OPCIONO)
# ============================================
NODE_OPTIONS=--max-old-space-size=4096
MAX_MEMORY=4GB
CPU_LIMIT=2
